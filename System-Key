-- Clicar em Get Key
GetKeyBtn.MouseButton1Click:Connect(function()
    setclipboard(KeyLink) -- Copia para o clipboard também
    Status.Text = "Link copied to clipboard!"
    Status.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    -- Abre o navegador (funciona na maioria dos executores)
    if select(2, pcall(function() return request end)) then
        request({Url = KeyLink, Method = "GET"})
    else
        -- Fallback para executores que usam openviewport ou similar
        local open = (syn and syn.request) or (http and http.request) or http_request
        if open then
            open({Url = KeyLink, Method = "GET"})
        end
    end
end)

